<Window x:Class="DevSpace.Dialogs.AddNoteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Note" Height="480" Width="430"
        WindowStartupLocation="CenterOwner" Background="{StaticResource BgPrimaryBrush}" Foreground="{StaticResource TextPrimaryBrush}"
        WindowStyle="ToolWindow">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Note Details" Style="{StaticResource Heading2}" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Title" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtTitle" Margin="0,0,0,15"/>

            <TextBlock Text="Linked Project" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
            <ComboBox x:Name="CmbProject" DisplayMemberPath="Title" SelectedValuePath="Id" Margin="0,0,0,15"/>

            <TextBlock Text="Tags (comma separated)" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtTags" Margin="0,0,0,15"/>

            <TextBlock Text="Content" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
            <TextBox x:Name="TxtContent" AcceptsReturn="True" TextWrapping="Wrap" Height="150"
                     VerticalScrollBarVisibility="Auto" Margin="0,0,0,15"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="Cancel_Click" Style="{StaticResource OutlineButtonStyle}" Margin="0,0,10,0"/>
            <Button Content="Save" Click="Save_Click" Style="{StaticResource PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
