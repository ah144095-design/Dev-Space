<Window x:Class="DevSpace.Dialogs.AddProjectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Project" Height="580" Width="460" MinHeight="480" MinWidth="420"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgPrimaryBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        ResizeMode="CanResizeWithGrip"
        Loaded="Window_Loaded">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <Border Height="3" CornerRadius="2" Margin="0,0,0,14" HorizontalAlignment="Left" Width="48" Background="{StaticResource AccentBrush}"/>
            <TextBlock x:Name="TxtHeading" Text="New Project" Style="{StaticResource PageTitleStyle}" FontSize="22"/>
            <TextBlock Text="Set where the project lives and which app opens when you press Launch."
                       Style="{StaticResource BodyText}" Margin="0,6,0,0" TextWrapping="Wrap"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
            <StackPanel>
                <TextBlock Text="Title" Style="{StaticResource FormLabelStyle}"/>
                <TextBox x:Name="TxtTitle" Style="{StaticResource FormTextBoxStyle}" Margin="0,0,0,14"/>

                <TextBlock Text="Local folder path" Style="{StaticResource FormLabelStyle}"/>
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtLocalPath" Style="{StaticResource FormTextBoxStyle}"/>
                    <Button Grid.Column="1" Content="Browse…" Click="BrowsePath_Click"
                            Style="{StaticResource OutlineButtonStyle}" Margin="8,0,0,0" Padding="12,8"/>
                </Grid>

                <TextBlock Text="Launch with" Style="{StaticResource FormLabelStyle}"/>
                <ComboBox x:Name="CmbLaunchWith" Style="{StaticResource DarkComboBoxStyle}"
                          DisplayMemberPath="Display" Margin="0,0,0,4"
                          SelectionChanged="CmbLaunchWith_SelectionChanged"/>
                <TextBlock x:Name="TxtLaunchHint" Style="{StaticResource BodyText}" FontSize="11"
                           Margin="0,0,0,8" TextWrapping="Wrap"/>
                           
                <StackPanel x:Name="PanelCustomLaunch" Visibility="Collapsed" Margin="0,0,0,14">
                    <TextBlock Text="Custom launcher path (.exe)" Style="{StaticResource FormLabelStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtCustomLaunch" Style="{StaticResource FormTextBoxStyle}"/>
                        <Button Grid.Column="1" Content="Browse…" Click="BrowseCustomLaunch_Click"
                                Style="{StaticResource OutlineButtonStyle}" Margin="8,0,0,0" Padding="12,8"/>
                    </Grid>
                </StackPanel>

                <TextBlock Text="GitHub URL" Style="{StaticResource FormLabelStyle}"/>
                <TextBox x:Name="TxtGitHubUrl" Style="{StaticResource FormTextBoxStyle}" Margin="0,0,0,14"/>

                <TextBlock Text="Tech stack (comma separated)" Style="{StaticResource FormLabelStyle}"/>
                <TextBox x:Name="TxtTechStack" Style="{StaticResource FormTextBoxStyle}" Margin="0,0,0,14"/>

                <TextBlock Text="Project color" Style="{StaticResource FormLabelStyle}"/>
                <WrapPanel x:Name="ColorSwatches" Margin="0,0,0,6"/>
                <TextBlock x:Name="TxtSelectedColor" Style="{StaticResource BodyText}" FontSize="11" Margin="0,0,0,14"/>

                <TextBlock Text="Status" Style="{StaticResource FormLabelStyle}"/>
                <ComboBox x:Name="CmbStatus" Style="{StaticResource DarkComboBoxStyle}"
                          DisplayMemberPath="Display" Margin="0,0,0,14"/>

                <TextBlock Text="Tags (comma separated)" Style="{StaticResource FormLabelStyle}"/>
                <TextBox x:Name="TxtTags" Style="{StaticResource FormTextBoxStyle}"/>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="0,16,0,0" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Click="Cancel_Click" Style="{StaticResource OutlineButtonStyle}" Margin="0,0,10,0"/>
                <Button Content="Save Project" Click="Save_Click" Style="{StaticResource PrimaryButtonStyle}"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
