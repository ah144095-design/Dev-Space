<UserControl x:Class="DevSpace.Views.SnippetsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Snippets" Style="{StaticResource PageTitleStyle}"/>
            <Button Grid.Column="1" Content="Add Snippet" Click="AddSnippet_Click" Style="{StaticResource PrimaryButtonStyle}"/>
        </Grid>

        <!-- Main split layout -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Language filter panel -->
            <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="8" Margin="0,0,16,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="LangFilterList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}" Tag="{Binding}" Click="LangFilter_Click"
                                        Style="{StaticResource IconButtonStyle}"
                                        HorizontalContentAlignment="Left"
                                        Padding="10,8" Margin="0,2"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Snippet cards -->
            <Grid Grid.Column="1">
                <TextBlock x:Name="EmptyState" Text="No snippets found. Click '+ Add Snippet' to get started."
                           Foreground="{StaticResource TextMutedBrush}" FontSize="14"
                           HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="SnippetsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardStyle}" Padding="15" Margin="0,0,0,10">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Title + Badges -->
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <!-- Language Badge -->
                                                <Border CornerRadius="10" Padding="8,2" Margin="10,0,0,0" Background="{StaticResource AccentSoftBrush}">
                                                    <TextBlock Text="{Binding Language}" FontSize="11" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold"/>
                                                </Border>
                                            </StackPanel>
                                            <!-- Favorite + Usage -->
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <TextBlock Text="★" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                                    <Setter Property="Foreground" Value="#F59E0B"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsFavorite}" Value="False">
                                                                    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Text="{Binding UsageCount, StringFormat='Used {0}x'}" Foreground="{StaticResource TextMutedBrush}" FontSize="11" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Description -->
                                        <TextBlock Grid.Row="1" Text="{Binding Description}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,6,0,8" TextTrimming="CharacterEllipsis"/>

                                        <!-- Code preview -->
                                        <Border Grid.Row="2" Background="#F5F2EE" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                                            <TextBlock Text="{Binding CodeBlock}" FontFamily="Consolas" FontSize="12"
                                                       Foreground="#57534E" MaxHeight="80" TextTrimming="CharacterEllipsis"
                                                       TextWrapping="Wrap"/>
                                        </Border>

                                        <!-- Actions -->
                                        <StackPanel Grid.Row="3" Orientation="Horizontal">
                                            <Button Content="Copy" Tag="{Binding Id}" Click="Copy_Click" Style="{StaticResource PrimaryButtonStyle}" Padding="10,5" Margin="0,0,5,0" FontSize="12"/>
                                            <Button Content="★ Fav" Tag="{Binding Id}" Click="ToggleFav_Click" Style="{StaticResource OutlineButtonStyle}" Padding="10,5" Margin="0,0,5,0" FontSize="12"/>
                                            <Button Content="Edit" Tag="{Binding Id}" Click="Edit_Click" Style="{StaticResource OutlineButtonStyle}" Padding="10,5" Margin="0,0,5,0" FontSize="12"/>
                                            <Button Content="Delete" Tag="{Binding Id}" Click="Delete_Click" Style="{StaticResource OutlineButtonStyle}" Padding="10,5" FontSize="12" Foreground="#F87171"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
