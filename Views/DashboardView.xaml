<UserControl x:Class="DevSpace.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Loaded="UserControl_Loaded">
    <UserControl.Resources>
        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource BgPrimaryBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="9,4" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="22,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Quick Launch -->
            <StackPanel Grid.Row="0" Margin="0,0,0,22">
                <Grid Margin="0,0,0,9">
                    <TextBlock Text="QUICK LAUNCH" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextGhostBrush}" />
                    <TextBlock Text="view all →" FontSize="11" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Right" Cursor="Hand" />
                </Grid>
                <ItemsControl x:Name="QuickLaunchItems">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Tag="{Binding Id}" Click="QuickLaunch_Click" Margin="0,0,7,7" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{DynamicResource CardBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12,6">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="⚡" FontSize="13" Foreground="{DynamicResource AccentBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Title}" FontSize="11.5" FontWeight="Medium" Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                <Setter TargetName="border" Property="Background" Value="{DynamicResource SurfaceElevatedBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Row 1: 4 Stats Cards -->
            <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,22">
                <Border Background="{DynamicResource CardBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,9,0">
                    <StackPanel>
                        <TextBlock Text="PROJECTS" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextGhostBrush}" Margin="0,0,0,7"/>
                        <TextBlock x:Name="StatTotalProjects" Text="0" FontSize="26" FontWeight="Medium" Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,3"/>
                        <TextBlock Text="4 active now" FontSize="11" Foreground="{DynamicResource StatusActiveBrush}"/>
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource CardBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,9,0">
                    <StackPanel>
                        <TextBlock Text="SNIPPETS" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextGhostBrush}" Margin="0,0,0,7"/>
                        <TextBlock x:Name="StatTotalSnippets" Text="0" FontSize="26" FontWeight="Medium" Foreground="{DynamicResource StatusActiveBrush}" Margin="0,0,0,3"/>
                        <TextBlock Text="+3 this week" FontSize="11" Foreground="{DynamicResource AccentBrush}"/>
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource CardBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,9,0">
                    <StackPanel>
                        <TextBlock Text="TOP LANGUAGE" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextGhostBrush}" Margin="0,0,0,7"/>
                        <TextBlock x:Name="StatTopLanguage" Text="C#" FontSize="18" FontWeight="Medium" Foreground="{DynamicResource AccentBlueBrush}" Margin="0,4,0,7" />
                        <TextBlock Text="18 snippets" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                    </StackPanel>
                </Border>
                <Border Background="{DynamicResource CardBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0">
                    <StackPanel>
                        <TextBlock Text="LAUNCHES" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextGhostBrush}" Margin="0,0,0,7"/>
                        <TextBlock x:Name="StatLaunchesToday" Text="0" FontSize="26" FontWeight="Medium" Foreground="{DynamicResource AccentVioletBrush}" Margin="0,0,0,3"/>
                        <TextBlock Text="last: Blood-Link" FontSize="11" Foreground="{DynamicResource TextMutedBrush}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Row 2: Recent Projects -->
            <StackPanel Grid.Row="2" Margin="0,0,0,20">
                <Grid Margin="0,0,0,9">
                    <TextBlock Text="RECENT PROJECTS" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextGhostBrush}"/>
                    <TextBlock Text="view all →" FontSize="11" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Right" Cursor="Hand" />
                </Grid>
                <ItemsControl x:Name="RecentProjectsList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="2"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="cardBorder" Background="{DynamicResource CardBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,9,9">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Border Width="36" Height="36" CornerRadius="8" Background="{DynamicResource AccentSoftBrush}" HorizontalAlignment="Left">
                                            <TextBlock Text="P" FontSize="18" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border HorizontalAlignment="Right" VerticalAlignment="Top" Background="{DynamicResource StatusActiveBgBrush}" CornerRadius="10" Padding="9,3">
                                            <TextBlock Text="{Binding Status}" FontSize="10" FontWeight="SemiBold" Foreground="{DynamicResource StatusActiveBrush}"/>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="{Binding Title}" FontSize="12.5" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,3"/>
                                    <TextBlock Text="Local developer workspace" FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,0,0,9" TextWrapping="Wrap"/>
                                    
                                    <ItemsControl ItemsSource="{Binding Tags}" Margin="0,0,0,9">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource BgSecondaryBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="0,0,4,4">
                                                    <TextBlock Text="{Binding}" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="0,9,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="▶ Launch" Tag="{Binding Id}" Click="LaunchProject_Click" Style="{StaticResource GhostButtonStyle}" Margin="0,0,5,0"/>
                                            <Button Content="★ GitHub" Tag="{Binding Id}" Click="GitHubProject_Click" Style="{StaticResource GhostButtonStyle}" Margin="0,0,5,0"/>
                                            <Button Content="■ Notes" Style="{StaticResource GhostButtonStyle}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                            <DataTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="cardBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    <Setter TargetName="cardBorder" Property="Background" Value="{DynamicResource CardHoverBrush}"/>
                                </Trigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Row 3: Bottom grid -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Margin="0,0,5,0">
                    <Grid Margin="0,0,0,9">
                        <TextBlock Text="SNIPPETS BY LANGUAGE" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextGhostBrush}" />
                        <TextBlock Text="vault →" FontSize="11" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Right" Cursor="Hand" />
                    </Grid>
                    <Border Background="{DynamicResource CardBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="14">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="C#" FontSize="11" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                                <Border Grid.Column="1" Background="{DynamicResource BgSecondaryBrush}" CornerRadius="4" Height="8">
                                    <Border HorizontalAlignment="Left" Width="180" Background="{DynamicResource AccentBrush}" CornerRadius="4"/>
                                </Border>
                                <TextBlock Grid.Column="2" Text="18" FontSize="10" Foreground="{DynamicResource TextGhostBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="JS" FontSize="11" Foreground="{DynamicResource AccentEmeraldBrush}" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                                <Border Grid.Column="1" Background="{DynamicResource BgSecondaryBrush}" CornerRadius="4" Height="8">
                                    <Border HorizontalAlignment="Left" Width="120" Background="{DynamicResource AccentEmeraldBrush}" CornerRadius="4"/>
                                </Border>
                                <TextBlock Grid.Column="2" Text="12" FontSize="10" Foreground="{DynamicResource TextGhostBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Py" FontSize="11" Foreground="{DynamicResource AccentBlueBrush}" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                                <Border Grid.Column="1" Background="{DynamicResource BgSecondaryBrush}" CornerRadius="4" Height="8">
                                    <Border HorizontalAlignment="Left" Width="80" Background="{DynamicResource AccentBlueBrush}" CornerRadius="4"/>
                                </Border>
                                <TextBlock Grid.Column="2" Text="8" FontSize="10" Foreground="{DynamicResource TextGhostBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="SQL" FontSize="11" Foreground="{DynamicResource AccentRoseBrush}" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                                <Border Grid.Column="1" Background="{DynamicResource BgSecondaryBrush}" CornerRadius="4" Height="8">
                                    <Border HorizontalAlignment="Left" Width="50" Background="{DynamicResource AccentRoseBrush}" CornerRadius="4"/>
                                </Border>
                                <TextBlock Grid.Column="2" Text="5" FontSize="10" Foreground="{DynamicResource TextGhostBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="HTML" FontSize="11" Foreground="{DynamicResource AccentVioletBrush}" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                                <Border Grid.Column="1" Background="{DynamicResource BgSecondaryBrush}" CornerRadius="4" Height="8">
                                    <Border HorizontalAlignment="Left" Width="40" Background="{DynamicResource AccentVioletBrush}" CornerRadius="4"/>
                                </Border>
                                <TextBlock Grid.Column="2" Text="4" FontSize="10" Foreground="{DynamicResource TextGhostBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    
                    <Grid Margin="0,10,0,9">
                        <TextBlock Text="TOP SNIPPET" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextGhostBrush}" />
                    </Grid>
                    <Border Background="{DynamicResource CardBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="14">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="8" Height="8" CornerRadius="4" Background="{DynamicResource AccentBrush}" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="SQLite Connection Helper" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border HorizontalAlignment="Right" Background="{DynamicResource AccentGlowBrush}" BorderBrush="{DynamicResource AccentSoftBrush}" BorderThickness="1" CornerRadius="5" Padding="8,3" Cursor="Hand">
                                    <TextBlock Text="Copy" FontSize="10" Foreground="{DynamicResource AccentBrush}"/>
                                </Border>
                            </Grid>
                            <Border Background="#1C1917" CornerRadius="7" Padding="12,10">
                                <TextBlock FontFamily="Consolas" FontSize="11" LineHeight="18">
                                    <Run Text="var " Foreground="#FDA44F"/><Run Text="conn = " Foreground="#F1F5F9"/><Run Text="new " Foreground="#FDA44F"/><Run Text="SqliteConnection" Foreground="#7EB8D8"/><Run Text="(" Foreground="#F1F5F9"/><Run Text="&quot;Data Source=app.db&quot;" Foreground="#6EBD8A"/><Run Text=");" Foreground="#F1F5F9"/><LineBreak/>
                                    <Run Text="conn." Foreground="#F1F5F9"/><Run Text="Open" Foreground="#7EB8D8"/><Run Text="();" Foreground="#F1F5F9"/><LineBreak/>
                                    <Run Text="// ready to execute" Foreground="#57534E"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Margin="5,0,0,0">
                    <Grid Margin="0,0,0,9">
                        <TextBlock Text="RECENT ACTIVITY" FontSize="9" FontWeight="SemiBold" Foreground="{DynamicResource TextGhostBrush}" />
                    </Grid>
                    <StackPanel>
                        <Border Background="{DynamicResource CardBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="11,9" Margin="0,0,0,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="28" Height="28" CornerRadius="7" Background="{DynamicResource AccentSoftBrush}" Margin="0,0,9,0">
                                    <TextBlock Text="▶" FontSize="12" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Grid.Column="1" FontSize="11.5" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" TextWrapping="Wrap">
                                    Launched <Run Text="Blood-Link" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold"/> in VS Code
                                </TextBlock>
                                <TextBlock Grid.Column="2" Text="2m ago" FontSize="10" Foreground="{DynamicResource TextGhostBrush}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <Border Background="{DynamicResource CardBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="11,9" Margin="0,0,0,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="28" Height="28" CornerRadius="7" Background="{DynamicResource StatusActiveBgBrush}" Margin="0,0,9,0">
                                    <TextBlock Text="⎘" FontSize="14" Foreground="{DynamicResource StatusActiveBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Grid.Column="1" FontSize="11.5" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" TextWrapping="Wrap">
                                    Copied <Run Text="SQLite Helper" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold"/> snippet
                                </TextBlock>
                                <TextBlock Grid.Column="2" Text="18m ago" FontSize="10" Foreground="{DynamicResource TextGhostBrush}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <Border Background="{DynamicResource CardBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="11,9" Margin="0,0,0,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="28" Height="28" CornerRadius="7" Background="{DynamicResource StatusCompletedBgBrush}" Margin="0,0,9,0">
                                    <TextBlock Text="📝" FontSize="11" Foreground="{DynamicResource StatusCompletedBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Grid.Column="1" FontSize="11.5" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" TextWrapping="Wrap">
                                    Updated note on <Run Text="DevSpace" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold"/>
                                </TextBlock>
                                <TextBlock Grid.Column="2" Text="1h ago" FontSize="10" Foreground="{DynamicResource TextGhostBrush}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <Border Background="{DynamicResource CardBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="11,9" Margin="0,0,0,6">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="28" Height="28" CornerRadius="7" Background="{DynamicResource StatusActiveBgBrush}" Margin="0,0,9,0">
                                    <TextBlock Text="★" FontSize="14" Foreground="{DynamicResource StatusActiveBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Grid.Column="1" FontSize="11.5" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Center" TextWrapping="Wrap">
                                    Starred <Run Text="LINQ GroupBy" Foreground="{DynamicResource TextSecondaryBrush}" FontWeight="SemiBold"/> snippet
                                </TextBlock>
                                <TextBlock Grid.Column="2" Text="5h ago" FontSize="10" Foreground="{DynamicResource TextGhostBrush}" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
