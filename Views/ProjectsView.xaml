<UserControl x:Class="DevSpace.Views.ProjectsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             Loaded="UserControl_Loaded">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Projects" Style="{StaticResource PageTitleStyle}"/>
                <TextBlock Text="Organize repositories and configure how each one opens."
                           Style="{StaticResource BodyText}" Margin="0,6,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="Add Project" Click="AddProject_Click"
                    Style="{StaticResource PrimaryButtonStyle}" VerticalAlignment="Center"/>
        </Grid>

        <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="14,10" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Status" VerticalAlignment="Center" Margin="0,0,14,0"
                           Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontWeight="SemiBold"/>
                <Button x:Name="BtnFilterAll" Content="All" Tag="All" Click="Filter_Click"
                        Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0" Padding="16,7"/>
                <Button x:Name="BtnFilterActive" Content="Active" Tag="Active" Click="Filter_Click"
                        Style="{StaticResource OutlineButtonStyle}" Margin="0,0,8,0" Padding="16,7"/>
                <Button x:Name="BtnFilterPaused" Content="Paused" Tag="Paused" Click="Filter_Click"
                        Style="{StaticResource OutlineButtonStyle}" Margin="0,0,8,0" Padding="16,7"/>
                <Button x:Name="BtnFilterCompleted" Content="Completed" Tag="Completed" Click="Filter_Click"
                        Style="{StaticResource OutlineButtonStyle}" Margin="0,0,8,0" Padding="16,7"/>
                <Border Width="1" Background="{StaticResource BorderBrush}" Margin="8,2,16,2"/>
                <TextBox x:Name="SearchBox" Width="240" Style="{StaticResource FormTextBoxStyle}"
                         TextChanged="SearchBox_TextChanged"/>
            </StackPanel>
        </Border>

        <TextBlock x:Name="EmptyState" Grid.Row="2"
                   Text="No projects yet. Create one to get started."
                   Foreground="{StaticResource TextMutedBrush}" FontSize="14"
                   HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ProjectsList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,12,12" CornerRadius="12" Background="#FFFFFF"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" CornerRadius="12,0,0,12">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Active">
                                                    <Setter Property="Background" Value="{StaticResource StatusActiveBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                    <Setter Property="Background" Value="{StaticResource StatusPausedBrush}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                    <Setter Property="Background" Value="{StaticResource StatusCompletedBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>
                                <Grid Grid.Column="1" Margin="18,18,18,16">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Title}" FontSize="17" FontWeight="SemiBold"/>
                                        <Border Grid.Column="1">
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource StatusChipStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Active">
                                                            <Setter Property="Background" Value="{StaticResource StatusActiveBgBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                            <Setter Property="Background" Value="{StaticResource StatusPausedBgBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                            <Setter Property="Background" Value="{StaticResource StatusCompletedBgBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Active">
                                                                <Setter Property="Foreground" Value="{StaticResource StatusActiveBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                                <Setter Property="Foreground" Value="{StaticResource StatusPausedBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                                <Setter Property="Foreground" Value="{StaticResource StatusCompletedBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                    <Border Grid.Row="1" Style="{StaticResource IdeBadgeStyle}">
                                        <TextBlock FontSize="11">
                                            <Run Text="Launch · " Foreground="{StaticResource TextMutedBrush}"/>
                                            <Run Text="{Binding LaunchAppDisplay, Mode=OneWay}"
                                                 Foreground="{StaticResource AccentCyanBrush}" FontWeight="SemiBold"/>
                                        </TextBlock>
                                    </Border>
                                    <TextBlock Grid.Row="2" Text="{Binding TechStack}"
                                               Style="{StaticResource BodyText}"
                                               Margin="0,10,0,4" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Row="3" Text="{Binding LocalPath}"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="11" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Row="4"
                                               Text="{Binding LastModified, StringFormat='Updated {0:MMM dd, yyyy}'}"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               FontSize="11" Margin="0,4,0,16"/>
                                    <StackPanel Grid.Row="5" Orientation="Horizontal">
                                        <Button Content="Launch" Tag="{Binding Id}" Click="Launch_Click"
                                                Style="{StaticResource PrimaryButtonStyle}" Padding="14,7" Margin="0,0,8,0"/>
                                        <Button Content="GitHub" Tag="{Binding Id}" Click="GitHub_Click"
                                                Style="{StaticResource OutlineButtonStyle}" Padding="14,7" Margin="0,0,8,0"/>
                                        <Button Content="Edit" Tag="{Binding Id}" Click="Edit_Click"
                                                Style="{StaticResource OutlineButtonStyle}" Padding="14,7" Margin="0,0,8,0"/>
                                        <Button Content="Delete" Tag="{Binding Id}" Click="Delete_Click"
                                                Style="{StaticResource GhostButtonStyle}" Padding="14,7"
                                                Foreground="{StaticResource AccentRoseBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
