<UserControl x:Class="DevSpace.Views.SearchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="SearchLabel" Text="Search" Style="{StaticResource PageTitleStyle}" Margin="0,0,0,24"/>

        <StackPanel x:Name="EmptyState" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Visible">
            <Border Width="56" Height="56" CornerRadius="14" Background="{StaticResource AccentGlowBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="0,0,0,18">
                <TextBlock Text="⌕" FontSize="26" Foreground="{StaticResource AccentHoverBrush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="Search your workspace" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            <TextBlock Text="Projects, snippets, and notes" FontSize="13"
                       Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,6,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ResultsPanel" Visibility="Collapsed">

                <!-- Projects Section -->
                <StackPanel x:Name="ProjectsSection" Visibility="Collapsed" Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Projects" Style="{StaticResource Heading2}"/>
                        <TextBlock x:Name="ProjectCount" Foreground="{StaticResource TextMutedBrush}" FontSize="13" VerticalAlignment="Bottom" Margin="8,0,0,2"/>
                    </StackPanel>
                    <ItemsControl x:Name="ProjectResults">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardStyle}" Padding="15" Margin="0,0,0,8" Cursor="Hand">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding TechStack}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,3,0,0"/>
                                            <TextBlock Text="{Binding LocalPath}" Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <Border Grid.Column="1" CornerRadius="10" Padding="8,3" VerticalAlignment="Top">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Active">
                                                            <Setter Property="Background" Value="#1A22C55E"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                            <Setter Property="Background" Value="#1AF59E0B"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                            <Setter Property="Background" Value="#1A8B5CF6"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Active">
                                                                <Setter Property="Foreground" Value="#22C55E"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                                <Setter Property="Foreground" Value="#F59E0B"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                                <Setter Property="Foreground" Value="#8B5CF6"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Snippets Section -->
                <StackPanel x:Name="SnippetsSection" Visibility="Collapsed" Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Snippets" Style="{StaticResource Heading2}"/>
                        <TextBlock x:Name="SnippetCount" Foreground="{StaticResource TextMutedBrush}" FontSize="13" VerticalAlignment="Bottom" Margin="8,0,0,2"/>
                    </StackPanel>
                    <ItemsControl x:Name="SnippetResults">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardStyle}" Padding="15" Margin="0,0,0,8">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <Border CornerRadius="10" Padding="8,2" Margin="10,0,0,0" Background="#2A4F46E5">
                                                <TextBlock Text="{Binding Language}" FontSize="11" Foreground="#818CF8"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                                        <Border Background="#0D0D1A" CornerRadius="4" Padding="8">
                                            <TextBlock Text="{Binding CodeBlock}" FontFamily="Consolas" FontSize="11"
                                                       Foreground="#A5D6A7" MaxHeight="40" TextTrimming="CharacterEllipsis" TextWrapping="Wrap"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Notes Section -->
                <StackPanel x:Name="NotesSection" Visibility="Collapsed" Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Notes" Style="{StaticResource Heading2}"/>
                        <TextBlock x:Name="NoteCount" Foreground="{StaticResource TextMutedBrush}" FontSize="13" VerticalAlignment="Bottom" Margin="8,0,0,2"/>
                    </StackPanel>
                    <ItemsControl x:Name="NoteResults">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource CardStyle}" Padding="15" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding LastEdited, StringFormat='Last edited: {0:MMM dd, yyyy}'}"
                                                   Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="0,0,0,6"/>
                                        <TextBlock Text="{Binding Content}" Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="12" TextTrimming="CharacterEllipsis" TextWrapping="Wrap" MaxHeight="40"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- No results -->
                <StackPanel x:Name="NoResults" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" Margin="0,60,0,0">
                    <TextBlock Text="😶 No results found" FontSize="18" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Try a different search term" FontSize="13" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
