<UserControl x:Class="DevSpace.Views.StatsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,24">

            <TextBlock Text="Analytics" Style="{StaticResource PageTitleStyle}"/>
            <TextBlock Text="Usage metrics across your workspace." Style="{StaticResource BodyText}" Margin="0,6,0,28"/>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="TOTAL PROJECTS" FontSize="11" FontWeight="SemiBold" Foreground="#A8A29E"/>
                        <TextBlock x:Name="CardTotalProjects" Text="0" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="20" Margin="5,0,5,0">
                    <StackPanel>
                        <TextBlock Text="ACTIVE PROJECTS" FontSize="11" FontWeight="SemiBold" Foreground="#A8A29E"/>
                        <TextBlock x:Name="CardActiveProjects" Text="0" FontSize="28" FontWeight="SemiBold" Foreground="#10B981" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="20" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="TOTAL SNIPPETS" FontSize="11" FontWeight="SemiBold" Foreground="#A8A29E"/>
                        <TextBlock x:Name="CardTotalSnippets" Text="0" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource AccentAmberBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Margin="0,0,0,28">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="20" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="FAVORITE SNIPPETS" FontSize="11" FontWeight="SemiBold" Foreground="#A8A29E"/>
                        <TextBlock x:Name="CardFavSnippets" Text="0" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource AccentRoseBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="20" Margin="5,0,5,0">
                    <StackPanel>
                        <TextBlock Text="TOTAL NOTES" FontSize="11" FontWeight="SemiBold" Foreground="#A8A29E"/>
                        <TextBlock x:Name="CardTotalNotes" Text="0" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource AccentCyanBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="12" Padding="20" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="TOTAL LAUNCHES" FontSize="11" FontWeight="SemiBold" Foreground="#A8A29E"/>
                        <TextBlock x:Name="CardTotalLaunches" Text="0" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource AccentVioletBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="22" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="Snippets by language" Style="{StaticResource Heading2}" Margin="0,0,0,18"/>
                        <ItemsControl x:Name="LangChart">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="36"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Language}" VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                        <Canvas Grid.Column="1" Height="10" Margin="8,0" VerticalAlignment="Center">
                                            <Rectangle Height="10" Width="{Binding BarWidth}" Fill="{Binding BarColor}" RadiusX="5" RadiusY="5"/>
                                        </Canvas>
                                        <TextBlock Grid.Column="2" Text="{Binding Count}" VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextMutedBrush}" FontSize="12" HorizontalAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock x:Name="NoLangData" Text="No snippet data yet." Foreground="{StaticResource TextMutedBrush}"
                                   Visibility="Collapsed" FontSize="13"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="22" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Project status" Style="{StaticResource Heading2}" Margin="0,0,0,18"/>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="10" Height="10" CornerRadius="5" Background="{StaticResource StatusActiveBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Active" VerticalAlignment="Center" Margin="10,0,0,0" Style="{StaticResource BodyText}"/>
                            <TextBlock Grid.Column="2" x:Name="StatusActive" Text="0" Foreground="{StaticResource StatusActiveBrush}" FontWeight="SemiBold"/>
                        </Grid>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="10" Height="10" CornerRadius="5" Background="{StaticResource StatusPausedBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Paused" VerticalAlignment="Center" Margin="10,0,0,0" Style="{StaticResource BodyText}"/>
                            <TextBlock Grid.Column="2" x:Name="StatusPaused" Text="0" Foreground="{StaticResource StatusPausedBrush}" FontWeight="SemiBold"/>
                        </Grid>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="10" Height="10" CornerRadius="5" Background="{StaticResource StatusCompletedBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Completed" VerticalAlignment="Center" Margin="10,0,0,0" Style="{StaticResource BodyText}"/>
                            <TextBlock Grid.Column="2" x:Name="StatusCompleted" Text="0" Foreground="{StaticResource StatusCompletedBrush}" FontWeight="SemiBold"/>
                        </Grid>

                        <Border Height="8" CornerRadius="4" ClipToBounds="True">
                            <Grid x:Name="StatusBar">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition x:Name="ColActive" Width="*"/>
                                    <ColumnDefinition x:Name="ColPaused" Width="*"/>
                                    <ColumnDefinition x:Name="ColCompleted" Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="{StaticResource StatusActiveBrush}"/>
                                <Border Grid.Column="1" Background="{StaticResource StatusPausedBrush}"/>
                                <Border Grid.Column="2" Background="{StaticResource StatusCompletedBrush}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource CardStyle}" Padding="22">
                <StackPanel>
                    <TextBlock Text="Most used snippet" Style="{StaticResource Heading2}" Margin="0,0,0,14"/>
                    <TextBlock x:Name="TopSnippetTitle" Text="—" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource AccentVioletBrush}"/>
                    <TextBlock x:Name="TopSnippetDesc" Text="" Style="{StaticResource BodyText}" Margin="0,6,0,12"/>
                    <Border Background="#F5F2EE" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="14">
                        <TextBlock x:Name="TopSnippetCode" FontFamily="Cascadia Code, Consolas" FontSize="12"
                                   Foreground="#57534E" TextWrapping="Wrap" MaxHeight="80" TextTrimming="CharacterEllipsis"/>
                    </Border>
                    <TextBlock x:Name="TopSnippetUsage" Text="" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
